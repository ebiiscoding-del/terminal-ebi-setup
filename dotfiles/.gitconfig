[user]
    name = Ebinezar Dhanaraj
    email = ebiiscoding@gmail.com

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    theme = Dracula
    line-numbers = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default
